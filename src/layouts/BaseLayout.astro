---
import { ClientRouter } from 'astro:transitions';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { personSchema, websiteSchema } from '@/lib/schema';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** Page-specific JSON-LD graph(s); Person + WebSite are always included. */
  schema?: object | object[];
}

const {
  title,
  description = 'Savelle McThias is a senior product designer and creative director specializing in trust and conversion moments for health and wellness products. Two decades of experience, available for remote senior and lead product design roles.',
  image = '/og-image.jpg',
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = 'Savelle McThias';

const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLdGraphs = [personSchema, websiteSchema, ...pageSchema];

// GA4 measurement ID is env-configurable (override per environment via
// PUBLIC_GA_MEASUREMENT_ID) with a fallback to the production property. The ID
// is public — it ships in the page HTML — so a committed fallback is safe.
// Only inject analytics in production builds so local dev and previews don't
// pollute the property.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-Q08TQD2DG9';
const enableAnalytics = import.meta.env.PROD && Boolean(GA_ID);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Gates all scroll-reveal hiding so no-JS visitors see full content -->
    <script is:inline>document.documentElement.classList.add('js');</script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Savelle McThias" />
    <meta name="keywords" content="senior product designer, creative director, health and wellness design, enrollment flow design, conversion design, product design leadership, remote product design, UX design, UI design, design systems, design engineering, React, front-end development, Scottsdale" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:creator" content="@savellem" />
    <meta name="twitter:site" content="@savellem" />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#0a0a0d" />

    <!-- Structured Data (JSON-LD) -->
    {jsonLdGraphs.map((graph) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} />
    ))}

    <!-- Google Analytics (production only, ID from PUBLIC_GA_MEASUREMENT_ID) -->
    {enableAnalytics && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </Fragment>
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

    <ClientRouter />
  </head>
  <body>
    <!-- Skip Links for Accessibility -->
    <a href="#main-content" class="skip-link">
      Skip to main content
    </a>

    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <script>
      // ── Global motion engine ──
      // One module for scroll reveals, image parallax, and utility
      // interactions. Runs once per site visit; astro:page-load re-inits
      // per-page element queries after every ClientRouter navigation
      // (and fires on initial load too).
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      let revealObserver: IntersectionObserver | null = null;
      let parallaxItems: { img: HTMLElement; container: HTMLElement; speed: number }[] = [];

      function initReveals() {
        revealObserver?.disconnect();
        const els = document.querySelectorAll('[data-reveal], [data-reveal-lines]');
        if (reducedMotion.matches) {
          els.forEach((el) => el.classList.add('is-inview'));
          return;
        }
        revealObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-inview');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
        );
        els.forEach((el) => revealObserver!.observe(el));
      }

      function initParallax() {
        parallaxItems = [];
        if (reducedMotion.matches) return;
        document.querySelectorAll<HTMLElement>('[data-parallax]').forEach((container) => {
          const img = container.querySelector('img');
          if (!img) return;
          const speed = parseFloat(container.getAttribute('data-parallax') || '24');
          parallaxItems.push({ img, container, speed });
        });
        updateParallax();
      }

      let parallaxTicking = false;
      function updateParallax() {
        const vh = window.innerHeight;
        for (const { img, container, speed } of parallaxItems) {
          const rect = container.getBoundingClientRect();
          if (rect.bottom < -120 || rect.top > vh + 120) continue;
          // -1 (below viewport) → 1 (above viewport), 0 at center
          const progress = (rect.top + rect.height / 2 - vh / 2) / (vh / 2 + rect.height / 2);
          img.style.transform = `translate3d(0, ${(progress * speed).toFixed(1)}px, 0) scale(1.12)`;
        }
        parallaxTicking = false;
      }

      window.addEventListener(
        'scroll',
        () => {
          if (!parallaxTicking && parallaxItems.length) {
            parallaxTicking = true;
            requestAnimationFrame(updateParallax);
          }
        },
        { passive: true }
      );

      // Delegated "back to top" control (footer)
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('[data-scroll-top]')) {
          window.scrollTo({ top: 0, behavior: reducedMotion.matches ? 'auto' : 'smooth' });
        }
      });

      document.addEventListener('astro:page-load', () => {
        initReveals();
        initParallax();
      });
    </script>

    <script>
      // ── Analytics ──
      // GA4 config fires once on initial load; ClientRouter navigations
      // are soft, so send page_view manually for each subsequent page.
      let firstLoad = true;
      document.addEventListener('astro:page-load', () => {
        if (firstLoad) {
          firstLoad = false;
          return;
        }
        const gtag = (window as any).gtag;
        if (typeof gtag !== 'function') return;
        gtag('event', 'page_view', {
          page_location: window.location.href,
          page_title: document.title,
        });
      });

      // Conversion tracking — fires GA4 events on key CTA clicks, detected by
      // destination so no per-button markup is needed.
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const link = target.closest('a');
        if (!link) return;
        const href = link.getAttribute('href') || '';
        const gtag = (window as any).gtag;
        if (typeof gtag !== 'function') return;

        if (href.includes('buy.stripe.com')) {
          gtag('event', 'begin_checkout', {
            currency: 'USD',
            value: 997,
            items: [{ item_name: '48-Hour UX Audit' }],
          });
        } else if (href === '/contact' || href.startsWith('/contact')) {
          // Soft intent — the real generate_lead fires on actual form submission.
          gtag('event', 'contact_intent', { method: 'contact_cta' });
        } else if (href.startsWith('mailto:')) {
          gtag('event', 'contact', { method: 'email' });
        } else if (href.startsWith('tel:')) {
          gtag('event', 'contact', { method: 'phone' });
        }
      });
    </script>
  </body>
</html>
