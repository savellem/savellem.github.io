---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Savelle McThias"
  description="The page you're looking for doesn't exist. Explore UX design case studies or learn more about Savelle McThias's design work."
>
  <section class="relative overflow-hidden min-h-svh flex items-center" data-pause-offscreen>
    <div class="glow-orb w-[34rem] h-[34rem] bg-ember/10 top-[-8rem] right-[-8rem]" aria-hidden="true"></div>

    <div class="container-custom relative text-center py-32">
      <p class="text-outline font-display font-bold text-[10rem] md:text-[16rem] leading-none select-none" aria-hidden="true">404</p>
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight -mt-6 mb-6">
        This page <em class="font-serif italic font-normal text-ember">wandered off</em>.
      </h1>
      <p class="text-lg text-fog mb-12 max-w-md mx-auto">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Go home</a>
        <a href="/work" class="btn-ghost">View my work</a>
      </div>

      <div class="mt-16 pt-10 border-t border-white/10 max-w-md mx-auto">
        <p class="eyebrow mb-6">Popular pages</p>
        <div class="flex flex-wrap gap-6 justify-center">
          <a href="/about" class="text-sm text-fog hover:text-paper transition-colors">About</a>
          <a href="/work" class="text-sm text-fog hover:text-paper transition-colors">Work</a>
          <a href="/contact" class="text-sm text-fog hover:text-paper transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
