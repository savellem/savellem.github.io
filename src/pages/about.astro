---
import BaseLayout from '@layouts/BaseLayout.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import { profilePageSchema, SITE_URL } from '@/lib/schema';

const pageSchema = profilePageSchema(`${SITE_URL}/about`);

const skills = [
  {
    group: 'Design',
    items: ['UX/UI Design', 'Atomic Design Systems', 'User Research', 'A/B Testing', 'AI-Enhanced Workflows'],
  },
  {
    group: 'Development',
    items: ['React & Angular', 'Component Architecture', 'Responsive Design', 'Accessibility (WCAG)', 'Performance Optimization'],
  },
  {
    group: 'Strategy',
    items: ['Digital Marketing', 'E-commerce Optimization', 'Analytics & ROI', 'Team Leadership', 'Cross-functional Collaboration'],
  },
];
---

<BaseLayout
  title="About — Savelle McThias | Senior Product Designer & Creative Director"
  description="Two decades designing for brands like PetSmart, Plexus Worldwide, and Green Compass, now focused on enrollment flows, dashboards, and the high-stakes moments where trust turns into a decision. Savelle McThias is a senior product designer and creative director based in Scottsdale, Arizona — available for remote senior and lead roles."
  schema={pageSchema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-36 md:pt-44 pb-20 md:pb-28">
    <div class="glow-orb w-[36rem] h-[36rem] bg-ember/10 top-[-10rem] right-[-10rem]" aria-hidden="true"></div>

    <!-- Desert landscape line art -->
    <svg
      class="absolute inset-x-0 bottom-0 w-full h-2/3 pointer-events-none select-none"
      viewBox="0 0 1400 600"
      preserveAspectRatio="xMidYMax slice"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Mountains -->
      <polyline points="0,600 180,280 320,420 500,180 680,380 820,240 1000,400 1150,200 1320,360 1400,300 1400,600" stroke="rgba(244,242,237,0.07)" stroke-width="1.5" stroke-linejoin="round" />
      <polyline points="0,600 140,340 280,460 460,230 640,420 780,290 960,440 1100,250 1270,390 1400,340 1400,600" stroke="rgba(244,242,237,0.04)" stroke-width="1" stroke-linejoin="round" />

      <!-- Saguaro cactus left -->
      <g stroke="rgba(244,242,237,0.09)" stroke-width="1.5" stroke-linecap="round">
        <line x1="1100" y1="600" x2="1100" y2="380" />
        <polyline points="1100,460 1068,460 1068,410" />
        <polyline points="1100,430 1132,430 1132,385" />
      </g>

      <!-- Saguaro cactus right -->
      <g stroke="rgba(244,242,237,0.07)" stroke-width="1.5" stroke-linecap="round">
        <line x1="1220" y1="600" x2="1220" y2="420" />
        <polyline points="1220,490 1196,490 1196,450" />
        <polyline points="1220,465 1244,465 1244,430" />
      </g>

      <!-- Tall saguaro far right -->
      <g stroke="rgba(244,242,237,0.05)" stroke-width="1.2" stroke-linecap="round">
        <line x1="1340" y1="600" x2="1340" y2="390" />
        <polyline points="1340,470 1318,470 1318,435" />
      </g>

      <!-- Agave bottom left -->
      <g stroke="rgba(244,242,237,0.08)" stroke-width="1.2" stroke-linecap="round">
        <line x1="80" y1="600" x2="60" y2="545" />
        <line x1="80" y1="600" x2="50" y2="560" />
        <line x1="80" y1="600" x2="40" y2="580" />
        <line x1="80" y1="600" x2="80" y2="535" />
        <line x1="80" y1="600" x2="110" y2="545" />
        <line x1="80" y1="600" x2="120" y2="562" />
        <line x1="80" y1="600" x2="118" y2="580" />
      </g>

      <!-- Agave mid right -->
      <g stroke="rgba(244,242,237,0.06)" stroke-width="1.2" stroke-linecap="round">
        <line x1="960" y1="600" x2="938" y2="548" />
        <line x1="960" y1="600" x2="928" y2="563" />
        <line x1="960" y1="600" x2="930" y2="582" />
        <line x1="960" y1="600" x2="960" y2="540" />
        <line x1="960" y1="600" x2="985" y2="548" />
        <line x1="960" y1="600" x2="992" y2="564" />
        <line x1="960" y1="600" x2="988" y2="582" />
      </g>

      <!-- Ground line -->
      <line x1="0" y1="598" x2="1400" y2="598" stroke="rgba(244,242,237,0.05)" stroke-width="1" />
    </svg>

    <div class="container-custom relative" data-reveal-lines>
      <h1 class="font-display font-bold text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[0.95] mb-14">
        <span class="reveal-line" style="--line-delay: .05s"><span><em class="font-serif italic font-normal text-ember">Designer.</em></span></span>
        <span class="reveal-line" style="--line-delay: .2s"><span>Builder.</span></span>
        <span class="reveal-line" style="--line-delay: .35s"><span>Desert dweller<span class="text-ember">.</span></span></span>
      </h1>

      <div class="max-w-3xl space-y-6" data-reveal style="--reveal-delay: .5s">
        <p class="text-xl md:text-2xl text-paper leading-relaxed">
          My superpower is a mix of intuition and ideas that seem obvious to me but apparently aren't obvious to everyone else. I've been taking things apart and putting them back together differently since I was a kid. Remote controlled cars, mostly. In high school I taught myself HTML and CSS in the school library and helped redesign sections of the school website. Nobody asked me to. I just wanted to see if I could.
        </p>
        <p class="text-lg text-fog leading-relaxed">
          Four decades of that same curiosity later and it's just how I think. Pattern recognition, creative problem solving, and a stubborn belief that most things can be done better. Those aren't skills I developed, they're just how I'm wired.
        </p>
        <p class="text-lg text-fog leading-relaxed">
          I'm based in Scottsdale with my bull terrier Diego, who makes life considerably stranger. I've spent the last decade practicing tarot as a decision-making framework, structured enough that I built an app around it. I also run a YouTube channel built on gaming and music, and somewhere in the long-term plan is either retiring to make music full time or opening a karaoke bar. Whichever comes first.
        </p>
      </div>
    </div>
  </section>

  <!-- Logo Bar -->
  <LogoMarquee />

  <!-- Reading sheet: experience + skills -->
  <section class="relative z-10 bg-white text-gray-900 rounded-t-[2.5rem] md:rounded-t-[3.5rem] mt-16 md:mt-24">
    <div class="container-custom py-16 md:py-24">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-[0.2em] mb-12" data-reveal>
          Professional Experience
        </p>

        <div class="space-y-12">
          <!-- Savelle LLC -->
          <div class="relative pl-8 border-l-2 border-gray-900" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-900"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">Founder & Principal Designer</h3>
              <p class="text-gray-600 font-medium">Savelle LLC • March 2021 - Present</p>
              <p class="text-sm text-gray-600 mt-1">Scottsdale, AZ</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              This is my own shop. I take on client work and build my own products, and I run on an AI-augmented workflow that lets me move fast without cutting corners.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Designed and built Card Ritual, a tarot journaling app, solo: product design, front and back end code, and brand</li>
              <li>Use Claude and Claude Code every day, from early concepts to shipped code</li>
            </ul>
          </div>

          <!-- Green Compass -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">Digital Experience Director</h3>
              <p class="text-gray-600 font-medium">Green Compass, LLC • February 2024 - November 2024</p>
              <p class="text-sm text-gray-600 mt-1">Scottsdale, AZ</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              I owned the digital side of the customer journey at this CBD wellness company: enrollment, branding, email, video, and the back office. It's a heavily regulated industry, so compliance had to be built into almost everything.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Redesigned the back office and self-service support tools, cutting customer service calls by 25%</li>
              <li>Simplified the enrollment flow, which dropped cart abandonment by 12% and increased enrollments by 15%</li>
              <li>Directed brand and content across email, social, web, and video, and built a design system so campaigns shipped faster</li>
            </ul>
          </div>

          <!-- iFoodDS -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">UI/UX Designer</h3>
              <p class="text-gray-600 font-medium">iFoodDS • January 2020 - March 2021</p>
              <p class="text-sm text-gray-600 mt-1">Scottsdale, Arizona</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              Redesigned the core product for an agriculture software company, used on phones and desktop by people in the field and in the office.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Reworked the main workflows so common tasks took fewer steps and generated fewer support tickets</li>
              <li>Rebuilt the interface with a modern JavaScript framework so it worked the same across devices</li>
              <li>Worked closely with the backend team to keep the front end and the API in sync</li>
            </ul>
          </div>

          <!-- SyberSafe -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">Front-end UI Developer</h3>
              <p class="text-gray-600 font-medium">SyberSafe • February 2019 - November 2019</p>
              <p class="text-sm text-gray-600 mt-1">Chandler, Arizona</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              Built the front end for a cybersecurity compliance platform used by more than 50,000 people, working alongside the dev team.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Built UI components in Angular and .NET</li>
              <li>Designed the brand identity and marketing materials</li>
              <li>Built layouts for dense data and dashboards that held up across screen sizes</li>
            </ul>
          </div>

          <!-- Plexus Worldwide -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">UI/UX Designer</h3>
              <p class="text-gray-600 font-medium">Plexus Worldwide • August 2016 - February 2019</p>
              <p class="text-sm text-gray-600 mt-1">Scottsdale, AZ</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              I was the first dedicated designer on the marketing team and led three major platform redesigns over two and a half years.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Designed and built a custom <span class="whitespace-nowrap">e-commerce</span> platform, replicated site builder, and back-office dashboard used by thousands of ambassadors</li>
              <li>Built an atomic design system with a Sketch component library that cut design-to-development handoff time by 60%</li>
              <li>Ran ongoing A/B tests to keep improving the product based on real data</li>
            </ul>
          </div>

          <!-- PetSmart -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">Senior Web Designer</h3>
              <p class="text-gray-600 font-medium">PetSmart • September 2015 - July 2016</p>
              <p class="text-sm text-gray-600 mt-1">Greater Phoenix Area</p>
            </div>
            <p class="text-gray-700 leading-relaxed mb-3">
              Worked on the <span class="whitespace-nowrap">e-commerce</span> redesign for a site with millions of monthly visitors, where even small changes had a big ripple effect.
            </p>
            <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
              <li>Owned the homepage experience, the highest-traffic page on the site</li>
              <li>Led design for the Universal Studios "Secret Life of Pets" brand partnership</li>
              <li>Reworked the checkout flow so more of that traffic converted</li>
            </ul>
          </div>

          <!-- Earlier Experience -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-xl font-display font-semibold text-gray-900">Earlier Roles</h3>
              <p class="text-gray-600 text-sm">2006 - 2015</p>
            </div>
            <p class="text-gray-700 leading-relaxed">
              Before that, roles at HomeSmart, Simple Sites, Xhibit Corp, and Zion & Zion took me through real estate tools, custom client sites, interactive museum exhibits, and <span class="whitespace-nowrap">e-commerce</span> and marketing work for clients like General Motors, the Arizona Science Center, and Sotheby's.
            </p>
          </div>

          <!-- Education Divider -->
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-[0.2em] pt-8 border-t border-gray-200">
            Education
          </h3>

          <!-- Education -->
          <div class="relative pl-8 border-l-2 border-gray-300" data-reveal>
            <div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-300"></div>
            <div class="mb-3">
              <h3 class="text-2xl font-display font-semibold text-gray-900">BA in Game Design</h3>
              <p class="text-gray-600 font-medium">Collins College • 2003 - 2006</p>
            </div>
            <p class="text-gray-700 leading-relaxed">
              Studied Game Design, Graphic Design, Computer Science, and Computer Arts
            </p>
          </div>
        </div>

        <!-- Skills & Expertise -->
        <div class="mt-20 pt-16 border-t border-gray-200">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-[0.2em] mb-12" data-reveal>
            Skills &amp; Expertise
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {skills.map(({ group, items }, i) => (
              <div data-reveal style={`--reveal-delay: ${i * 0.1}s`}>
                <h3 class="text-xl font-display font-semibold text-gray-900 mb-6">{group}</h3>
                <ul class="space-y-3 text-gray-700">
                  {items.map((item) => (
                    <li class="flex items-start gap-3">
                      <span class="mt-[0.55em] w-1.5 h-1.5 rounded-full bg-ember shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- Closing -->
        <p class="mt-20 pt-12 border-t border-gray-200 text-center text-xl md:text-2xl text-gray-700">
          Anyway, that's <em class="font-serif italic">me</em>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
