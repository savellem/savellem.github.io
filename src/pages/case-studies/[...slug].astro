---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import NumbersBlock from '@components/case-study/NumbersBlock.astro';
import { creativeWorkSchema, breadcrumbListSchema, SITE_URL } from '@/lib/schema';
import { EXCLUDED_SLUGS } from '@/lib/caseStudies';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  // Prev/Next cycles through the same visible, ordered set shown on /work,
  // wrapping around at both ends. Legacy/excluded pages get no nav.
  const visible = caseStudies
    .filter((s) => !EXCLUDED_SLUGS.has(s.id))
    .sort((a, b) => (a.data.homepageOrder ?? 99) - (b.data.homepageOrder ?? 99));

  return caseStudies.map((study) => {
    const index = visible.findIndex((s) => s.id === study.id);
    const hasNav = index !== -1 && visible.length > 1;
    const prevStudy = hasNav ? visible[(index - 1 + visible.length) % visible.length] : undefined;
    const nextStudy = hasNav ? visible[(index + 1) % visible.length] : undefined;
    return {
      params: { slug: study.id },
      props: { study, prevStudy, nextStudy },
    };
  });
}

const { study, prevStudy, nextStudy } = Astro.props;
const { Content } = await render(study);

// Role, Team, and Timeline surface beside the headline; Model and Scope
// break down into keyword pills under the subheadline instead.
const HERO_DETAIL_LABELS = ['Role', 'Team', 'Timeline'];
const allDetails = study.data.details ?? [];
const heroDetails = allDetails.filter((d) => HERO_DETAIL_LABELS.includes(d.label));
const pillKeywords = allDetails
  .filter((d) => !HERO_DETAIL_LABELS.includes(d.label))
  .flatMap((d) => d.value.split('·').map((s) => s.trim()))
  .filter(Boolean);

const caseUrl = `${SITE_URL}/case-studies/${study.id}`;
const pageSchema = [
  creativeWorkSchema({
    name: study.data.title,
    description: study.data.description,
    url: caseUrl,
    image: study.data.thumbnail,
    datePublished: study.data.publishDate.toISOString().slice(0, 10),
    keywords: study.data.tags,
    about: study.data.project,
  }),
  breadcrumbListSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Case Studies', url: `${SITE_URL}/work` },
    { name: study.data.client, url: caseUrl },
  ]),
];
---

<BaseLayout
  title={`${study.data.title} - ${study.data.client}`}
  description={study.data.description}
  image={study.data.thumbnail}
  schema={pageSchema}
>
  <Breadcrumbs items={[
    { label: 'Case Studies', href: '/work' },
    { label: study.data.client, href: `/case-studies/${study.id}` },
  ]} />

  <!-- Header -->
  <section class="container-custom pt-10 pb-16 bg-gradient-to-b from-gray-50 to-white">
    <a
      href="/work"
      class="inline-flex items-center text-sm text-gray-500 hover:text-gray-900 transition-colors mb-8"
    >
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Work
    </a>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-900 leading-tight mb-10">
      {study.data.title}
    </h1>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 mb-12">
      <!-- Left: subheadline -->
      <div class="lg:w-1/2">
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-6">
          {study.data.description}
        </p>

        {pillKeywords.length > 0 && (
          <div class="border-t border-gray-200 pt-4">
            <p class="text-sm md:text-base font-semibold text-gray-900">
              {pillKeywords.map((keyword, i) => (
                <>
                  {i > 0 && <span class="text-gray-400 mx-2">&bull;</span>}
                  {keyword}
                </>
              ))}
            </p>
          </div>
        )}
      </div>

      <!-- Right: Role / Team / Timeline -->
      {heroDetails.length > 0 && (
        <div class="lg:w-1/2 flex">
          <div class="w-full divide-y divide-gray-200 border-t border-gray-200">
            {heroDetails.map((item) => (
              <div class="flex items-start justify-between py-3">
                <span class="text-gray-500 shrink-0 mr-4">{item.label}</span>
                <span class="text-gray-900 text-right">{item.value}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Numbers -->
  {study.data.outcomes && study.data.outcomes.length > 0 && (
    <section class="container-custom mb-16">
      <NumbersBlock stats={study.data.outcomes} />
    </section>
  )}

  <!-- Main Content -->
  <section class="container-custom mb-16">
    <div class="prose-custom">
      <Content />
    </div>
  </section>

  <!-- Prev / Next Navigation -->
  {prevStudy && nextStudy && (
    <section class="container-custom py-16">
      <div class="grid grid-cols-2 gap-6 border-t border-gray-200 pt-8">
        <a
          href={`/case-studies/${prevStudy.id}`}
          class="group"
        >
          <p class="inline-flex items-center text-sm text-gray-500 group-hover:text-gray-900 transition-colors mb-2">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Previous
          </p>
          <p class="text-lg md:text-xl font-display font-bold text-gray-900 leading-snug">
            {prevStudy.data.client}
          </p>
        </a>
        <a
          href={`/case-studies/${nextStudy.id}`}
          class="group text-right"
        >
          <p class="inline-flex items-center justify-end text-sm text-gray-500 group-hover:text-gray-900 transition-colors mb-2">
            Next
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </p>
          <p class="text-lg md:text-xl font-display font-bold text-gray-900 leading-snug">
            {nextStudy.data.client}
          </p>
        </a>
      </div>
    </section>
  )}
</BaseLayout>
