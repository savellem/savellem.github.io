---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import NumbersBlock from '@components/case-study/NumbersBlock.astro';
import { creativeWorkSchema, breadcrumbListSchema, SITE_URL } from '@/lib/schema';
import { EXCLUDED_SLUGS } from '@/lib/caseStudies';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  // Prev/Next cycles through the same visible, ordered set shown on /work,
  // wrapping around at both ends. Legacy/excluded pages get no nav.
  const visible = caseStudies
    .filter((s) => !EXCLUDED_SLUGS.has(s.id))
    .sort((a, b) => (a.data.homepageOrder ?? 99) - (b.data.homepageOrder ?? 99));

  return caseStudies.map((study) => {
    const index = visible.findIndex((s) => s.id === study.id);
    const hasNav = index !== -1 && visible.length > 1;
    const prevStudy = hasNav ? visible[(index - 1 + visible.length) % visible.length] : undefined;
    const nextStudy = hasNav ? visible[(index + 1) % visible.length] : undefined;
    return {
      params: { slug: study.id },
      props: { study, prevStudy, nextStudy },
    };
  });
}

const { study, prevStudy, nextStudy } = Astro.props;
const { Content } = await render(study);

// Role, Team, and Timeline surface beside the headline; Model and Scope
// break down into keyword pills under the subheadline instead.
const HERO_DETAIL_LABELS = ['Role', 'Team', 'Timeline'];
const allDetails = study.data.details ?? [];
const heroDetails = allDetails.filter((d) => HERO_DETAIL_LABELS.includes(d.label));
const pillKeywords = allDetails
  .filter((d) => !HERO_DETAIL_LABELS.includes(d.label))
  .flatMap((d) => d.value.split('·').map((s) => s.trim()))
  .filter(Boolean);

const caseUrl = `${SITE_URL}/case-studies/${study.id}`;
// study.data.thumbnail is build-time ImageMetadata (see content.config.ts),
// not a URL string — meta tags and JSON-LD need the resolved asset path.
const thumbnailSrc = study.data.thumbnail?.src;
const pageSchema = [
  creativeWorkSchema({
    name: study.data.title,
    description: study.data.description,
    url: caseUrl,
    image: thumbnailSrc,
    datePublished: study.data.publishDate.toISOString().slice(0, 10),
    keywords: study.data.tags,
    about: study.data.project,
  }),
  breadcrumbListSchema([
    { name: 'Home', url: SITE_URL },
    { name: 'Case Studies', url: `${SITE_URL}/work` },
    { name: study.data.client, url: caseUrl },
  ]),
];
---

<BaseLayout
  title={`${study.data.title} - ${study.data.client}`}
  description={study.data.description}
  image={thumbnailSrc}
  schema={pageSchema}
>
  <!-- Reading progress -->
  <div id="read-progress" class="fixed top-0 left-0 h-[3px] bg-ember z-[80] w-0" aria-hidden="true"></div>

  <!-- Dark hero -->
  <section class="relative overflow-hidden pt-28 md:pt-32 pb-16 md:pb-20">
    <div class="glow-orb w-[36rem] h-[36rem] bg-ember/10 -top-48 right-[-10rem]" aria-hidden="true"></div>

    <Breadcrumbs items={[
      { label: 'Case Studies', href: '/work' },
      { label: study.data.client, href: `/case-studies/${study.id}` },
    ]} />

    <div class="container-custom relative pt-6" data-reveal-lines>
      <h1 class="font-display font-bold text-4xl md:text-6xl lg:text-7xl tracking-tight leading-[0.98] mb-12 max-w-5xl">
        <span class="reveal-line"><span>{study.data.title}</span></span>
      </h1>

      <div class="flex flex-col lg:flex-row gap-10 lg:gap-20 mb-4">
        <!-- Left: subheadline + pills -->
        <div class="lg:w-1/2" data-reveal style="--reveal-delay: .15s">
          <p class="text-lg md:text-xl text-fog leading-relaxed mb-6">
            {study.data.description}
          </p>

          {pillKeywords.length > 0 && (
            <div class="flex flex-wrap gap-2 border-t border-white/10 pt-5">
              {pillKeywords.map((keyword) => (
                <span class="inline-flex items-center rounded-full border border-white/15 px-3.5 py-1.5 text-xs font-medium text-paper/80">
                  {keyword}
                </span>
              ))}
            </div>
          )}
        </div>

        <!-- Right: Role / Team / Timeline -->
        {heroDetails.length > 0 && (
          <div class="lg:w-1/2 flex" data-reveal style="--reveal-delay: .25s">
            <div class="w-full divide-y divide-white/10 border-t border-white/10 self-start">
              {heroDetails.map((item) => (
                <div class="flex items-start justify-between py-3.5 gap-6">
                  <span class="text-fog/60 shrink-0 text-sm">{item.label}</span>
                  <span class="text-paper/90 text-right text-sm">{item.value}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Numbers -->
  {study.data.outcomes && study.data.outcomes.length > 0 && (
    <section class="container-custom mb-16 md:mb-20">
      <NumbersBlock stats={study.data.outcomes} />
    </section>
  )}

  <!-- Reading sheet: light long-form so the design thinking stays readable -->
  <section class="relative z-10 bg-white text-gray-900 rounded-t-[2.5rem] md:rounded-t-[3.5rem]">
    <div class="container-custom py-16 md:py-24">
      <div class="prose-custom">
        <Content />
      </div>
    </div>
  </section>

  <!-- Prev / Next Navigation -->
  {prevStudy && nextStudy && (
    <section class="border-t border-white/10">
      <div class="grid grid-cols-1 sm:grid-cols-2">
        <a
          href={`/case-studies/${prevStudy.id}`}
          class="group container-custom sm:!pr-8 py-14 md:py-20 border-b sm:border-b-0 sm:border-r border-white/10 hover:bg-ink-soft transition-colors duration-500"
        >
          <p class="inline-flex items-center gap-2 text-sm text-fog group-hover:text-paper transition-colors mb-4">
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Previous
          </p>
          <p class="font-display font-bold text-3xl md:text-4xl text-paper leading-tight">
            {prevStudy.data.client}
          </p>
        </a>
        <a
          href={`/case-studies/${nextStudy.id}`}
          class="group container-custom sm:!pl-8 py-14 md:py-20 text-right hover:bg-ink-soft transition-colors duration-500"
        >
          <p class="inline-flex items-center justify-end gap-2 text-sm text-fog group-hover:text-paper transition-colors mb-4">
            Next
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </p>
          <p class="font-display font-bold text-3xl md:text-4xl text-paper leading-tight">
            {nextStudy.data.client}
          </p>
        </a>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  import { onPageReady } from '@/lib/pageReady';

  // Reading progress bar — width tracks document scroll. Element only
  // exists on case study pages; re-queried each navigation.
  let bar: HTMLElement | null = null;

  function updateProgress() {
    if (!bar) return;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const progress = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
    bar.style.width = `${(progress * 100).toFixed(2)}%`;
  }

  // rAF-throttled, not a raw per-scroll-event listener: iOS fires 'scroll'
  // at high frequency during momentum scrolling, and each one was forcing
  // a synchronous style write (and the layout recalc that comes with it).
  // Case study pages are the only place this exists, and it was compounding
  // with everything else the page does while scrolling (reveal observers,
  // image decode) into real, felt jank/stalls specifically there.
  let progressTicking = false;
  window.addEventListener(
    'scroll',
    () => {
      if (!progressTicking) {
        progressTicking = true;
        requestAnimationFrame(() => {
          updateProgress();
          progressTicking = false;
        });
      }
    },
    { passive: true }
  );
  onPageReady(() => {
    bar = document.getElementById('read-progress');
    updateProgress();
  });
</script>
