---
import BaseLayout from '@layouts/BaseLayout.astro';
import FeaturedCaseStudy from '@components/FeaturedCaseStudy.astro';
import { getCollection } from 'astro:content';

// Get the 3 homepage-featured case studies ordered by homepageOrder
const caseStudies = (await getCollection('case-studies'))
  .filter((study) => study.data.homepageFeatured)
  .sort((a, b) => (a.data.homepageOrder ?? 99) - (b.data.homepageOrder ?? 99))
  .slice(0, 4);
---

<BaseLayout
  title="Savelle McThias — Product Designer & Creative Director, Scottsdale AZ"
  description="Savelle McThias is a product designer and creative director based in Scottsdale, AZ. Web design, branding, and development for Phoenix area businesses. Senior product design and design engineering for remote teams. Two decades of experience."
>
  <!-- Hero Intro (H1 + positioning) -->
  <section class="relative container-custom pt-24 pb-16 overflow-hidden">
    <!-- Abstract UI element line art -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none select-none"
      viewBox="0 0 1400 600"
      preserveAspectRatio="xMidYMid slice"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Dashboard card: window frame with header dots -->
      <g stroke="rgba(255,255,255,0.06)" stroke-width="1.2">
        <rect x="1180" y="70" width="200" height="170" rx="14" />
        <line x1="1180" y1="110" x2="1380" y2="110" />
        <circle cx="1198" cy="90" r="3" />
        <circle cx="1210" cy="90" r="3" />
        <circle cx="1222" cy="90" r="3" />
      </g>
      <!-- Content rows inside the card -->
      <g stroke="rgba(255,255,255,0.05)" stroke-width="1.2" stroke-linecap="round">
        <line x1="1198" y1="135" x2="1300" y2="135" />
        <line x1="1198" y1="155" x2="1270" y2="155" />
      </g>
      <!-- Small bar chart, bottom of the card -->
      <g stroke="rgba(255,255,255,0.06)" stroke-width="1.2" stroke-linecap="round">
        <line x1="1198" y1="225" x2="1360" y2="225" />
        <line x1="1205" y1="225" x2="1205" y2="200" />
        <line x1="1228" y1="225" x2="1228" y2="210" />
        <line x1="1251" y1="225" x2="1251" y2="190" />
        <line x1="1274" y1="225" x2="1274" y2="215" />
        <line x1="1297" y1="225" x2="1297" y2="205" />
        <line x1="1320" y1="225" x2="1320" y2="195" />
      </g>

      <!-- Enrollment flow: connected nodes, between the two cards -->
      <g stroke="rgba(255,255,255,0.045)" stroke-width="1.2">
        <circle cx="1230" cy="268" r="6" />
        <circle cx="1330" cy="268" r="6" />
        <line x1="1240" y1="268" x2="1320" y2="268" stroke-dasharray="3 5" />
      </g>

      <!-- Floating stat card with sparkline -->
      <g stroke="rgba(255,255,255,0.045)" stroke-width="1.2">
        <rect x="1180" y="300" width="200" height="130" rx="12" />
      </g>
      <g stroke="rgba(255,255,255,0.05)" stroke-width="1.2" stroke-linecap="round">
        <line x1="1198" y1="326" x2="1260" y2="326" />
        <polyline points="1198,405 1223,390 1248,398 1273,375 1298,385 1323,365 1348,378" />
      </g>

      <!-- Cursor near the sparkline -->
      <path
        d="M0,0 L0,18 L4.5,14 L7,20 L9.5,19 L7,13 L12,13 Z"
        fill="rgba(255,255,255,0.06)"
        transform="translate(1343,360)"
      />

      <!-- Toggle switch, below the stat card -->
      <g stroke="rgba(255,255,255,0.05)" stroke-width="1.2">
        <rect x="1180" y="450" width="50" height="26" rx="13" />
        <circle cx="1217" cy="463" r="9" />
      </g>

      <!-- Primary button, below the stat card -->
      <rect x="1245" y="446" width="100" height="34" rx="17" stroke="rgba(255,255,255,0.06)" stroke-width="1.2" />
    </svg>

    <div class="max-w-5xl mx-auto text-left relative">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-100 tracking-tight leading-[1.05] mb-4">
        I design the moment someone becomes a customer, patient, or member. 
      </h1>
      <p class="text-xl md:text-2xl font-medium text-gray-300 leading-snug mb-6">
        For health and wellness products. And I build them with code.
      </p>
      <p class="text-lg md:text-xl text-gray-400 leading-snug max-w-3xl">
        Enrollment flows, patient dashboards, and conversion systems. 18 years of experience, currently building with Claude and Claude Code daily.
      </p>
    </div>
  </section>

  <!-- Featured Work Section -->
  {caseStudies.length > 0 && (
    <section id="featured-work" class="container-custom pt-20 pb-8">
      <div class="mb-4 flex items-end justify-between">
        <div>
          <h2 class="text-sm font-semibold text-gray-100 uppercase tracking-wider mb-3">
            Featured Work
          </h2>
          <p class="text-gray-400 text-lg">
            Recent projects and case studies
          </p>
        </div>
        <a
          href="/work"
          class="hidden md:inline-flex items-center text-sm font-medium text-gray-100 hover:text-gray-300 transition-colors group"
        >
          View all case studies
          <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div>
        {caseStudies.map((study) => (
          <FeaturedCaseStudy
            title={study.data.title}
            client={study.data.client}
            year={study.data.year}
            yearEnd={study.data.yearEnd}
            description={study.data.description}
            role={study.data.role}
            scope={study.data.scope}
            media={study.data.media}
            thumbnail={study.data.thumbnail}
            slug={study.id}
          />
        ))}
      </div>

      <div class="mt-12 text-center md:hidden">
        <a
          href="/work"
          class="inline-flex items-center text-sm font-medium text-gray-100 hover:text-gray-300 transition-colors group"
        >
          View all case studies
          <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </section>
  )}

  <!-- CTA Section -->
  <section class="container-custom py-32">
    <div class="bg-zinc-950 rounded-3xl p-16 md:p-24 text-center border border-zinc-800">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-100 mb-6 tracking-tight">
        Let's talk about your product.
      </h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto">
        If you're hiring for a senior or lead product design role, or want to talk about enrollment and conversion work, reach out.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 border-2 border-zinc-700 text-gray-100 text-base font-medium rounded-full hover:bg-zinc-900 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
<script>
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute('href');
      const target = href ? document.querySelector(href) : null;
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
</BaseLayout>
