---
import BaseLayout from '@layouts/BaseLayout.astro';
import FeaturedCaseStudy from '@components/FeaturedCaseStudy.astro';
import { getCollection } from 'astro:content';

// Get the 3 homepage-featured case studies ordered by homepageOrder
const caseStudies = (await getCollection('case-studies'))
  .filter((study) => study.data.homepageFeatured)
  .sort((a, b) => (a.data.homepageOrder ?? 99) - (b.data.homepageOrder ?? 99))
  .slice(0, 4);
---

<BaseLayout
  title="Savelle McThias — Product Designer & Creative Director, Scottsdale AZ"
  description="Savelle McThias is a product designer and creative director based in Scottsdale, AZ. Web design, branding, and development for Phoenix area businesses. Senior product design and design engineering for remote teams. Two decades of experience."
>
  <!-- Hero Intro (H1 + positioning) -->
  <section class="relative container-custom pt-24 pb-16 overflow-hidden">
    <div class="max-w-2xl mx-auto text-center relative">
      <h1 class="text-3xl md:text-4xl text-gray-900 font-medium mb-8 leading-snug">
        There's a moment right before someone becomes a customer, a patient, a member. Their thumb hovers. They're deciding whether to trust you.
      </h1>
      <p class="text-4xl md:text-5xl text-gray-900 font-serif font-medium italic mb-8 leading-snug">
        I design that moment.
      </p>
      <p class="text-3xl md:text-4xl text-gray-900 font-medium mb-8 leading-snug">
        For health and wellness products. And I build them with code.
      </p>
    </div>
  </section>

  <!-- Featured Work Section -->
  {caseStudies.length > 0 && (
    <section id="featured-work" class="container-custom pt-20 pb-8">
      <div class="mb-4 flex items-end justify-between">
        <div>
          <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">
            Featured Work
          </h2>
          <p class="text-gray-600 text-lg">
            Recent projects and case studies
          </p>
        </div>
        <a
          href="/work"
          class="hidden md:inline-flex items-center text-sm font-medium text-gray-900 hover:text-gray-700 transition-colors group"
        >
          View all case studies
          <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div>
        {caseStudies.map((study) => (
          <FeaturedCaseStudy
            title={study.data.title}
            client={study.data.client}
            year={study.data.year}
            yearEnd={study.data.yearEnd}
            description={study.data.description}
            role={study.data.role}
            scope={study.data.scope}
            media={study.data.media}
            thumbnail={study.data.thumbnail}
            slug={study.id}
          />
        ))}
      </div>

      <div class="mt-12 text-center md:hidden">
        <a
          href="/work"
          class="inline-flex items-center text-sm font-medium text-gray-900 hover:text-gray-700 transition-colors group"
        >
          View all case studies
          <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </section>
  )}

  <!-- CTA Section -->
  <section class="container-custom py-32">
    <div class="bg-gray-50 rounded-3xl p-16 md:p-24 text-center border border-gray-200">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 tracking-tight">
        Let's talk about your product.
      </h2>
      <p class="text-xl text-gray-700 mb-10 max-w-2xl mx-auto">
        If you're hiring for a senior or lead product design role, or want to talk about enrollment and conversion work, reach out.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 border-2 border-gray-300 text-gray-900 text-base font-medium rounded-full hover:bg-gray-100 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
<script>
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute('href');
      const target = href ? document.querySelector(href) : null;
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
</BaseLayout>
