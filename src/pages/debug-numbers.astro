---
// TEMPORARY diagnostic page — round 3. Round 1 (just NumbersBlock) and
// round 2 (+ real lazy-loaded images after it) both scrolled clean,
// ruling out NumbersBlock, the base motion system, and lazy images. This
// round adds LogoMarquee right before NumbersBlock (matching the
// homepage's actual Hero → LogoMarquee → NumbersBlock order) since it has
// the longest, most-modified history in this investigation and hasn't
// been tested in isolation yet. Delete this page once done.
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import NumbersBlock from '@components/case-study/NumbersBlock.astro';
import img1 from '@/assets/case-studies/cs-cr-001.png';
import img2 from '@/assets/case-studies/cs-gs-003.png';
import img3 from '@/assets/case-studies/cs-y-002.png';
import img4 from '@/assets/case-studies/cs-gs-004.png';

const stats = [
  { stat: '25%', label: 'reduction in customer service calls' },
  { stat: '12%', label: 'decrease in cart abandonment' },
  { stat: '15%', label: 'increase in distributor enrollments' },
  { stat: '90 days', label: 'from design to launch' },
];
const images = [img1, img2, img3, img4];
---

<BaseLayout title="Debug: Numbers freeze isolation test, round 3">
  <div class="min-h-svh flex items-center justify-center text-center px-6">
    <p class="text-2xl text-fog">Scroll down to reach the logo row, then the numbers section.</p>
  </div>

  <LogoMarquee eyebrow="Isolation test — logos" />

  <section class="container-custom py-24">
    <NumbersBlock stats={stats} eyebrow="Isolation test" />
  </section>

  <section class="container-custom pb-24 space-y-8">
    {images.map((img) => (
      <Image src={img} alt="" format="webp" quality={82} widths={[640, 960, 1440]} sizes="100vw" class="w-full rounded-2xl" loading="lazy" decoding="async" />
    ))}
  </section>

  <div class="min-h-svh flex items-center justify-center text-center px-6">
    <p class="text-2xl text-fog">Past everything. If you scrolled through without a freeze, LogoMarquee isn't it either.</p>
  </div>
</BaseLayout>
