---
// TEMPORARY diagnostic page — round 4. Rounds 1-3 (NumbersBlock alone,
// + real lazy images, + LogoMarquee) all scrolled clean, ruling out
// NumbersBlock, the base motion system, lazy images, and LogoMarquee.
// This round adds the hero's glow-orb (the blurred background element) —
// the last piece of real-page content not yet tested in isolation.
// Delete this page once done.
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import LogoMarquee from '@components/LogoMarquee.astro';
import NumbersBlock from '@components/case-study/NumbersBlock.astro';
import img1 from '@/assets/case-studies/cs-cr-001.png';
import img2 from '@/assets/case-studies/cs-gs-003.png';
import img3 from '@/assets/case-studies/cs-y-002.png';
import img4 from '@/assets/case-studies/cs-gs-004.png';

const stats = [
  { stat: '25%', label: 'reduction in customer service calls' },
  { stat: '12%', label: 'decrease in cart abandonment' },
  { stat: '15%', label: 'increase in distributor enrollments' },
  { stat: '90 days', label: 'from design to launch' },
];
const images = [img1, img2, img3, img4];
---

<BaseLayout title="Debug: Numbers freeze isolation test, round 4">
  <div class="relative min-h-svh flex items-center justify-center text-center px-6 overflow-hidden">
    <div class="glow-orb w-[42rem] h-[42rem] bg-ember/15 -top-40 -right-40" aria-hidden="true"></div>
    <div class="glow-orb w-[36rem] h-[36rem] bg-indigo-500/10 bottom-[-12rem] left-[-10rem]" style="animation-delay: -11s" aria-hidden="true"></div>
    <p class="relative text-2xl text-fog">Scroll down to reach the logo row, then the numbers section.</p>
  </div>

  <LogoMarquee eyebrow="Isolation test — logos" />

  <section class="container-custom py-24">
    <NumbersBlock stats={stats} eyebrow="Isolation test" />
  </section>

  <section class="container-custom pb-24 space-y-8">
    {images.map((img) => (
      <Image src={img} alt="" format="webp" quality={82} widths={[640, 960, 1440]} sizes="100vw" class="w-full rounded-2xl" loading="lazy" decoding="async" />
    ))}
  </section>

  <div class="min-h-svh flex items-center justify-center text-center px-6">
    <p class="text-2xl text-fog">Past everything. If you scrolled through without a freeze, glow-orb isn't it either — we're out of real-page ingredients to test.</p>
  </div>
</BaseLayout>
