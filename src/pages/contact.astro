---
import BaseLayout from '@layouts/BaseLayout.astro';
import { realTestimonials } from '@/data/testimonials';

const testimonial = realTestimonials[0];
---

<BaseLayout
  title="Contact — Savelle McThias"
  description="Get in touch with Savelle McThias about senior or lead product design roles, or enrollment and conversion work."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-40 md:pt-48 pb-24" data-pause-offscreen>
    <div class="glow-orb w-[38rem] h-[38rem] bg-ember/12 top-[-8rem] left-1/2 -translate-x-1/2" aria-hidden="true"></div>

    <div class="container-custom relative max-w-4xl mx-auto text-center" data-reveal-lines>
      <p class="eyebrow mb-6" data-reveal>Contact</p>
      <h1 class="font-display font-bold text-6xl md:text-8xl tracking-tight leading-[0.92] mb-10">
        <span class="reveal-line" style="--line-delay: .1s"><span>Let's <em class="font-serif italic font-normal text-ember">talk</em>.</span></span>
      </h1>
      <p class="text-lg md:text-xl text-fog leading-relaxed max-w-2xl mx-auto mb-14" data-reveal style="--reveal-delay: .3s">
        If you're hiring for a senior or lead product design role, or want to talk about enrollment
        and conversion work, I'd love to hear from you.
      </p>

      <div class="flex flex-col items-center gap-8" data-reveal style="--reveal-delay: .45s">
        <a
          href="mailto:savellem@gmail.com"
          class="link-underline inline-flex items-center gap-3 font-display font-semibold text-2xl md:text-4xl text-paper"
        >
          savellem@gmail.com
          <svg class="w-6 h-6 md:w-8 md:h-8 text-ember" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7v8" />
          </svg>
        </a>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="https://www.linkedin.com/in/savelle"
            target="_blank"
            rel="noopener"
            class="btn-ghost"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
            </svg>
            linkedin.com/in/savelle
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  {testimonial && (
    <section class="container-custom pb-28 md:pb-36">
      <figure class="max-w-3xl mx-auto text-center border-t border-white/10 pt-16" data-reveal>
        <svg class="w-8 h-8 text-ember mx-auto mb-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9.6 4.8C5.8 7 3.6 10.2 3.6 14c0 3.2 1.9 5.2 4.4 5.2 2.2 0 3.9-1.7 3.9-3.9 0-2.1-1.5-3.7-3.5-3.7-.4 0-.9.1-1 .1.3-2.3 2.4-5 4.5-6.2L9.6 4.8zm10.4 0C16.2 7 14 10.2 14 14c0 3.2 1.9 5.2 4.4 5.2 2.2 0 3.9-1.7 3.9-3.9 0-2.1-1.5-3.7-3.5-3.7-.4 0-.8.1-1 .1.3-2.3 2.4-5 4.5-6.2L20 4.8z" />
        </svg>
        <blockquote class="text-xl md:text-2xl text-paper leading-relaxed mb-8 font-light">
          &ldquo;{testimonial.quote}&rdquo;
        </blockquote>
        <figcaption class="text-sm">
          <span class="text-paper font-semibold">{testimonial.name}</span>
          <span class="text-fog"> · {testimonial.title}, {testimonial.company}</span>
        </figcaption>
      </figure>
    </section>
  )}
</BaseLayout>
