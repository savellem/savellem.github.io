---
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  return currentPath === path || (path !== '/' && currentPath.startsWith(path));
}

const navItems = [
  { name: 'Work', path: '/work' },
  { name: 'About', path: '/about' },
];
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-transform duration-500 ease-out"
>
  <nav class="container-custom pt-4 md:pt-5">
    <div class="flex items-center justify-between gap-3">
      <!-- Brand chip -->
      <a
        href="/"
        class="flex items-center gap-3 rounded-full bg-ink/70 backdrop-blur-md border border-white/10 p-1.5 pr-5 transition-colors hover:border-white/25"
      >
        <img
          src="/images/profile-avatar.webp"
          alt="Savelle McThias"
          width="40"
          height="40"
          class="w-9 h-9 rounded-full object-cover shrink-0"
        />
        <span class="flex flex-col leading-tight">
          <span class="text-sm font-semibold text-paper tracking-tight">Savelle McThias</span>
          <span class="hidden sm:block text-[0.65rem] font-medium text-fog tracking-[0.14em] uppercase whitespace-nowrap">Product Designer &amp; Creative Director</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-3">
        <div class="flex items-center gap-1 rounded-full bg-ink/70 backdrop-blur-md border border-white/10 p-1.5">
          {navItems.map((item) => (
            <a
              href={item.path}
              class={`px-5 py-2 rounded-full text-sm font-medium transition-colors ${
                isActive(item.path)
                  ? 'bg-white/10 text-paper'
                  : 'text-fog hover:text-paper'
              }`}
            >
              {item.name}
            </a>
          ))}
        </div>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-paper text-ink text-sm font-semibold transition-all duration-300 hover:bg-white hover:-translate-y-0.5"
        >
          Contact
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7v8" />
          </svg>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        class="md:hidden relative z-[70] flex items-center justify-center w-12 h-12 rounded-full bg-ink/70 backdrop-blur-md border border-white/10 text-paper"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="relative block w-5 h-3.5">
          <span class="hamburger-bar bar-top absolute inset-x-0 top-0 h-[2px] rounded-full bg-current"></span>
          <span class="hamburger-bar bar-mid absolute inset-x-0 top-1/2 -translate-y-1/2 h-[2px] rounded-full bg-current"></span>
          <span class="hamburger-bar bar-bottom absolute inset-x-0 bottom-0 h-[2px] rounded-full bg-current"></span>
        </span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile menu: full-screen overlay with staggered links -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-[60] bg-ink/95 backdrop-blur-xl opacity-0 pointer-events-none transition-opacity duration-400"
  aria-hidden="true"
>
  <nav class="h-full container-custom flex flex-col justify-center">
    <p class="eyebrow mb-8 menu-item">Menu</p>
    {[{ name: 'Home', path: '/' }, ...navItems, { name: 'Contact', path: '/contact' }].map((item, i) => (
      <a
        href={item.path}
        class={`menu-item group flex items-baseline gap-4 py-3 font-display font-bold text-5xl tracking-tight transition-colors ${
          isActive(item.path) && item.path !== '/' ? 'text-paper' : 'text-fog hover:text-paper'
        } ${item.path === '/' && currentPath === '/' ? 'text-paper' : ''}`}
        style={`transition-delay: ${80 + i * 60}ms`}
      >
        <span class="text-sm font-sans font-medium text-fog/60 tabular-nums">0{i + 1}</span>
        {item.name}
      </a>
    ))}
    <div class="menu-item mt-12 pt-8 border-t border-white/10 flex flex-col gap-2" style="transition-delay: 400ms">
      <a href="mailto:savellem@gmail.com" class="text-fog hover:text-paper transition-colors">savellem@gmail.com</a>
      <p class="text-sm text-fog/60">Scottsdale, AZ — working remotely</p>
    </div>
  </nav>
</div>

<style>
  .hamburger-bar {
    transition: transform 300ms ease, opacity 200ms ease;
  }

  #mobile-menu-button.is-open .bar-top {
    transform: translateY(6px) rotate(45deg);
  }

  #mobile-menu-button.is-open .bar-mid {
    opacity: 0;
  }

  #mobile-menu-button.is-open .bar-bottom {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Staggered link entrance while the overlay fades in */
  .menu-item {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }
  #mobile-menu.is-open .menu-item {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Header + mobile menu behavior. Module runs once per visit; element
  // bindings refresh on astro:page-load since ClientRouter swaps the DOM.
  let header: HTMLElement | null = null;
  let isOpen = false;
  let lastY = 0;

  function setOpen(open: boolean) {
    isOpen = open;
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    button?.classList.toggle('is-open', open);
    button?.setAttribute('aria-expanded', String(open));

    if (open) {
      menu?.classList.remove('opacity-0', 'pointer-events-none');
      menu?.classList.add('opacity-100', 'is-open');
    } else {
      menu?.classList.remove('opacity-100', 'is-open');
      menu?.classList.add('opacity-0', 'pointer-events-none');
    }

    menu?.setAttribute('aria-hidden', String(!open));
    document.documentElement.classList.toggle('overflow-hidden', open);
  }

  // Hide on scroll down, reveal on scroll up — never while the menu is open.
  window.addEventListener(
    'scroll',
    () => {
      if (!header || isOpen) return;
      const y = window.scrollY;
      const goingDown = y > lastY;
      header.classList.toggle('-translate-y-[130%]', goingDown && y > 240);
      lastY = y;
    },
    { passive: true }
  );

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) setOpen(false);
  });

  // Collapse if the viewport grows past the mobile breakpoint mid-open.
  window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
    if (e.matches && isOpen) setOpen(false);
  });

  document.addEventListener('astro:page-load', () => {
    header = document.getElementById('site-header');
    lastY = window.scrollY;
    isOpen = false;
    document.documentElement.classList.remove('overflow-hidden');

    document.getElementById('mobile-menu-button')?.addEventListener('click', () => setOpen(!isOpen));
    // Close before navigating so the overlay doesn't linger through the transition.
    document.querySelectorAll('#mobile-menu a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  });
</script>
