---
interface Stat {
  stat: string;
  label: string;
}

interface Props {
  stats: Stat[];
  eyebrow?: string;
}

const { stats, eyebrow = 'The Numbers' } = Astro.props;

// Literal class strings (not template-interpolated) so Tailwind's scanner picks them up.
const gridClass = stats.length >= 4 ? 'sm:grid-cols-2 lg:grid-cols-4' : 'sm:grid-cols-3';
---

<div class="rounded-2xl bg-gray-50 px-8 py-10 md:px-14 md:py-14">
  <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-8">{eyebrow}</p>
  <div class={`grid grid-cols-1 ${gridClass} divide-y sm:divide-y-0 sm:divide-x divide-white`}>
    {stats.map((item) => (
      <div class="py-6 first:pt-0 last:pb-0 sm:py-0 sm:px-8 sm:first:pl-0">
        <p class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-gray-900 leading-none mb-3">
          {item.stat}
        </p>
        <p class="text-sm md:text-base text-gray-600 leading-snug">{item.label}</p>
      </div>
    ))}
  </div>
</div>
