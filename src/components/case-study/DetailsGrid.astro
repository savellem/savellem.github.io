---
interface DetailItem {
  label: string;
  value: string;
}

interface Props {
  items: DetailItem[];
}

const { items } = Astro.props;

// Literal class strings (not template-interpolated) so Tailwind's scanner picks them up.
const lgColsClass = items.length >= 5
  ? 'lg:grid-cols-5'
  : items.length === 4
    ? 'lg:grid-cols-4'
    : items.length === 3
      ? 'lg:grid-cols-3'
      : 'lg:grid-cols-2';
---

<div class={`grid grid-cols-1 sm:grid-cols-2 ${lgColsClass} gap-x-8 gap-y-8 border-t border-gray-200 pt-8`}>
  {items.map((item) => (
    <div>
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-2">{item.label}</p>
      <p class="text-gray-900 leading-snug">{item.value}</p>
    </div>
  ))}
</div>
