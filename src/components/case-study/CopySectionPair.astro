---
interface Props {
  leftTitle: string;
  rightTitle: string;
}

const { leftTitle, rightTitle } = Astro.props;
---

<section class="mt-16 md:mt-20 pt-16 md:pt-20 border-t border-gray-200">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
    <div>
      <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-8">{leftTitle}</h2>
      <slot name="left" />
    </div>
    <div>
      <h2 class="text-2xl md:text-3xl font-display font-bold text-gray-900 mb-8">{rightTitle}</h2>
      <slot name="right" />
    </div>
  </div>
</section>
