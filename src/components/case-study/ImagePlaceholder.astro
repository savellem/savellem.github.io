---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  width: number;
  height: number;
  /** Placeholder-box label shown before a real image is added. Not needed once `src` + `alt` are set. */
  replace?: string;
  caption: string;
  /** Constrains box width for portrait/mobile mockups so they don't stretch full-bleed. */
  narrow?: boolean;
  /** Width cap when narrow: 'sm' (default, phone mockup) or 'md' (signature/featured visual). */
  size?: 'sm' | 'md';
  class?: string;
  /** Once set, renders the real image instead of the dashed placeholder box.
   *  Import from src/assets/ (not a public/ string path) so it gets
   *  optimized and re-encoded to webp at build time. */
  src?: ImageMetadata;
  /** Alt text for the real image. Required for a real, non-empty alt attribute — falls back to `replace` or `caption` if omitted, but pass this explicitly. */
  alt?: string;
}

const { width, height, replace, caption, narrow = false, size = 'sm', class: className, src, alt } = Astro.props;
const resolvedAlt = alt ?? replace ?? caption;
const margin = className !== undefined ? className : 'my-12 md:my-16';
const narrowWidthClass = size === 'md' ? 'max-w-sm sm:max-w-md' : 'max-w-xs sm:max-w-sm';
const widthClass = narrow ? `${narrowWidthClass} mx-auto` : 'w-full';
// Once a real image is set, size the box to its actual dimensions rather
// than the manually-typed width/height props — those two can drift apart
// (wrong prop values crop/letterbox the image against object-cover) and
// the real ImageMetadata is always correct.
const boxAspect = src ? `${src.width} / ${src.height}` : `${width} / ${height}`;
---

{src ? (
  <div
    class={`${widthClass} rounded-2xl overflow-hidden ${margin}`}
    style={`aspect-ratio: ${boxAspect};`}
    data-reveal
  >
    <Image src={src} alt={resolvedAlt} format="webp" quality={95} class="w-full h-full object-cover" loading="lazy" decoding="async" />
  </div>
) : (
  <div
    class={`${widthClass} bg-zinc-900 border border-dashed border-zinc-700 rounded-2xl flex flex-col items-center justify-center px-8 py-10 text-center gap-3 ${margin}`}
    style={`aspect-ratio: ${boxAspect};`}
  >
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest">REPLACE: {replace}</p>
    <p class="text-gray-600 text-sm max-w-lg leading-relaxed">{caption}</p>
    <p class="text-gray-700 text-xs font-mono">{width} &times; {height}px</p>
  </div>
)}
