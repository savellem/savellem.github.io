---
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-white/10">
  <!-- CTA -->
  <div class="container-custom pt-24 md:pt-32 pb-16" data-reveal>
    <p class="eyebrow mb-6">Next step</p>
    <h2 class="font-display font-bold text-5xl md:text-7xl lg:text-8xl tracking-tight leading-[0.95] mb-10 max-w-5xl">
      Let's design the moment they say <span class="font-serif italic font-normal text-ember">yes.</span>
    </h2>
    <p class="text-lg md:text-xl text-fog max-w-xl mb-12 leading-relaxed">
      Hiring for a senior or lead product design role, or thinking about enrollment and conversion work? I'd love to hear about it.
    </p>
    <a
      href="mailto:savellem@gmail.com"
      class="link-underline inline-flex items-center gap-3 text-2xl md:text-4xl font-display font-semibold text-paper"
    >
      savellem@gmail.com
      <svg class="w-6 h-6 md:w-8 md:h-8 text-ember" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7v8" />
      </svg>
    </a>
  </div>

  <!-- Meta grid -->
  <div class="container-custom pb-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 pt-14 border-t border-white/10">
      <div>
        <h4 class="eyebrow mb-5">Navigate</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-fog hover:text-paper transition-colors">Home</a></li>
          <li><a href="/work" class="text-sm text-fog hover:text-paper transition-colors">Work</a></li>
          <li><a href="/about" class="text-sm text-fog hover:text-paper transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-fog hover:text-paper transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="eyebrow mb-5">Connect</h4>
        <ul class="space-y-3">
          <li>
            <a href="https://www.linkedin.com/in/savelle" target="_blank" rel="noopener" class="text-sm text-fog hover:text-paper transition-colors">LinkedIn</a>
          </li>
          <li>
            <a href="mailto:savellem@gmail.com" class="text-sm text-fog hover:text-paper transition-colors">Email</a>
          </li>
          <li>
            <a href="/Resume-Savelle-McThias-2025.pdf" target="_blank" rel="noopener" class="text-sm text-fog hover:text-paper transition-colors">Résumé</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="eyebrow mb-5">Location</h4>
        <p class="text-sm text-fog leading-relaxed">
          Scottsdale, Arizona<br />
          Working remotely, everywhere
        </p>
        <p class="text-sm text-fog mt-3 tabular-nums">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-ember pulse-dot mr-2 align-middle"></span>Local time <span data-local-time>—</span>
        </p>
      </div>
      <div>
        <h4 class="eyebrow mb-5">Status</h4>
        <p class="text-sm text-fog leading-relaxed">
          Open to senior &amp; lead product design roles.
        </p>
      </div>
    </div>
  </div>

  <!-- Watermark -->
  <div class="relative h-[16vw] min-h-24 overflow-hidden pointer-events-none select-none" aria-hidden="true">
    <p class="text-outline absolute left-1/2 -translate-x-1/2 bottom-[-0.28em] font-display font-bold text-[19vw] leading-none whitespace-nowrap tracking-tight">
      SAVELLE
    </p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-custom py-6 flex flex-wrap items-center justify-between gap-4">
      <p class="text-xs text-fog/70">
        &copy; {currentYear} Savelle McThias. Designed and built by me, with Claude.
      </p>
      <button
        data-scroll-top
        class="text-xs text-fog hover:text-paper transition-colors inline-flex items-center gap-2 cursor-pointer"
      >
        Back to top
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
      </button>
    </div>
  </div>
</footer>

<script>
  // Live Scottsdale clock — Arizona doesn't observe DST, so a fixed
  // timeZone is always right.
  function tick() {
    const els = document.querySelectorAll('[data-local-time]');
    if (!els.length) return;
    const time = new Intl.DateTimeFormat('en-US', {
      hour: 'numeric',
      minute: '2-digit',
      timeZone: 'America/Phoenix',
    }).format(new Date());
    els.forEach((el) => (el.textContent = time));
  }
  setInterval(tick, 30_000);
  document.addEventListener('astro:page-load', tick);
</script>
